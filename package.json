{
	"name": "hono-standard",
	"version": "1.0.0",
	"description": "Minimal Hono + React template with optional login and showcase screens.",
	"type": "module",
	"author": "",
	"license": "MIT",
	"keywords": [
		"hono",
		"react",
		"vite",
		"typescript"
	],
	"scripts": {
		"dev": "bunx --bun vite",
		"dev:vite": "vite",
		"start": "bun run api/app/server.ts",
		"auth:create-admin": "bun run api/cli/auth-create-admin.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run api/cli/migrate.ts",
		"db:migrate:drizzle": "drizzle-kit migrate",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint api web shared",
		"format": "biome format --write api web shared",
		"format:check": "biome format api web shared",
		"build:web": "vite build",
		"build": "bun run build:web",
		"verify": "bun scripts/verify.ts",
		"verify:strict": "bun run verify"
	},
	"files": [
		"dist-web",
		"README.md",
		"LICENSE.md",
		"package.json"
	],
	"dependencies": {
		"@hono/zod-validator": "0.8.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-router": "1.170.15",
		"@tanstack/react-table": "8.21.3",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.25",
		"jose": "6.2.3",
		"lucide-react": "1.18.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "^7.79.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@hono/vite-dev-server": "0.26.0",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "1.3.14",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"drizzle-kit": "0.31.10",
		"tailwindcss": "^4.3.1",
		"typescript": "5.9.3",
		"vite": "8.0.16",
		"vitest": "4.1.8"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"picomatch": "4.0.4",
		"postcss": "8.5.15",
		"rollup": "4.62.0",
		"undici": "7.27.2",
		"vite": "8.0.16",
		"ws": "8.21.0"
	}
}
